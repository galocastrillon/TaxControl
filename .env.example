# Gemini API Key
GEMINI_API_KEY=

# Database Configuration
# En Coolify: usar el hostname interno del servicio MariaDB (ej. postgresql o mariadb-service-name)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=tax_control
DB_PORT=3306

# Entorno (production | development)
NODE_ENV=production

# CORS — dominio(s) permitidos. Usar el dominio configurado en Coolify.
# Para múltiples orígenes separar con coma: https://app.tudominio.com,https://tudominio.com
ALLOWED_ORIGIN=https://tudominio.com
