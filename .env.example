# Gemini API Key
GEMINI_API_KEY=

# Database Configuration
# En Coolify: usar el hostname interno del servicio MariaDB (ej. postgresql o mariadb-service-name)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=tax_control
DB_PORT=3306

# Entorno (production | development)
NODE_ENV=production

# CORS — dominio(s) permitidos. Usar el dominio configurado en Coolify.
ALLOWED_ORIGIN=https://tudominio.com

# SMTP — configuración de correo saliente para notificaciones
# Exchange/OWA: usar el hostname del servidor OWA, puerto 587 con STARTTLS
# Formato de usuario en dominio Windows: DOMINIO\usuario  (ej. ecsa\monitoreo)
SMTP_HOST=owa1.corriente.com.ec
SMTP_PORT=587
SMTP_USER=ecsa\monitoreo
SMTP_PASS=tu-password
SMTP_FROM=monitoreo@corriente.com.ec
SMTP_FROM_NAME=TaxControl ECSA
