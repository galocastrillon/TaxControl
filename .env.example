# Gemini API Key
GEMINI_API_KEY=

# Database Configuration
# En Coolify: usar el hostname interno del servicio MariaDB (ej. postgresql o mariadb-service-name)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=tax_control
DB_PORT=3306

# Entorno (production | development)
NODE_ENV=production

# CORS — dominio(s) permitidos. Usar el dominio configurado en Coolify.
ALLOWED_ORIGIN=https://tudominio.com

# SMTP — configuración de correo saliente para notificaciones
# Ejemplos: smtp.gmail.com (Gmail), smtp.office365.com (Outlook), mail.yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password
SMTP_FROM=Tax Control <tu-correo@gmail.com>
